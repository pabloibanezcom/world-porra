# API
PORT=3000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/world-porra
JWT_SECRET=change-me-to-a-random-256-bit-string
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
FOOTBALL_DATA_API_KEY=your-football-data-api-key
SYNC_API_KEY=change-me-random-string
POLL_PICKS_DEADLINE=
POLL_GROUP_PREDICTIONS_DEADLINE=
POLL_TOURNAMENT_PREDICTIONS_DEADLINE=
APP_BASE_URL=https://app.worldporra.com
RESEND_API_KEY=
EMAIL_FROM=World Porra <notifications@worldporra.com>
EMAIL_REPLY_TO=
EMAIL_DAILY_LIMIT=90
EMAIL_PWA_RECENT_DAYS=30

# App
EXPO_PUBLIC_APP_URL=https://app.worldporra.com
EXPO_PUBLIC_API_URL=https://world-porra-api.vercel.app
EXPO_PUBLIC_API_SCENARIO=pre-tournament
EXPO_PUBLIC_ENABLE_SCENARIO_SWITCHER=true
