                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"password\": \"supersecret123\"\n}"
            }
          }
        },
        {
          "name": "Google Login (real ID token required)",
          "description": "Requires a real Google ID token issued for the configured GOOGLE_CLIENT_ID. The placeholder value is intentionally invalid; use Dev Login for normal local/staging QA when the API is pointed at a test database.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('authToken', json.token); }",
                  "if (json.user?.id) { pm.collectionVariables.set('memberUserId', json.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "google"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{google_id_token}}\"\n}"
            }
          }
        },
        {
          "name": "Dev Login (recommended for QA)",
          "description": "Use this first for local/staging QA. It is available only when the API is using a test database or in-memory/test mode, and saves authToken and memberUserId.",
