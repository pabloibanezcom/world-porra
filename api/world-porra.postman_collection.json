              "raw": "{{baseUrl}}/auth/dev",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "dev"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
