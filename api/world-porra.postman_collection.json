{
  "info": {
    "name": "World Porra API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the World Porra REST API. Use Dev Login against local/test scenario databases, or set authToken manually for hosted environments."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "hostedBaseUrl",
      "value": "https://world-porra-api.vercel.app",
      "type": "string"
    },
    {
      "key": "scenario",
      "value": "pre-tournament",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "matchId",
      "value": "",
      "type": "string"
    },
    {
      "key": "leagueId",
      "value": "",
      "type": "string"
    },
    {
      "key": "inviteCode",
      "value": "",
      "type": "string"
    },
    {
      "key": "memberUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "syncApiKey",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Health for Scenario",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health?scenario={{scenario}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ],
              "query": [
                {
                  "key": "scenario",
                  "value": "{{scenario}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('authToken', json.token); }",
                  "if (json.user?.id) { pm.collectionVariables.set('memberUserId', json.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"name\": \"Player One\",\n  \"password\": \"supersecret123\"\n}"
            }
          }
        },
        {
          "name": "Password Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('authToken', json.token); }",
                  "if (json.user?.id) { pm.collectionVariables.set('memberUserId', json.user.id); }"
                ],
                "type": "text/javascript"
              }
