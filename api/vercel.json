{
  "version": 2,
  "builds": [
    {
      "src": "src/serverless.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/src/serverless.ts" }
  ],
  "crons": [
    {
      "path": "/cron/daily-odds",
      "schedule": "0 7 * * *"
    }
  ]
}
