{
  "info": {
    "name": "WC2026 Predict API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "matchId",
      "value": "",
      "type": "string"
    },
    {
      "key": "leagueId",
      "value": "",
      "type": "string"
    },
    {
      "key": "memberUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "syncApiKey",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"name\": \"Player One\",\n  \"password\": \"supersecret123\"\n}"
            }
          }
        },
        {
          "name": "Password Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"password\": \"supersecret123\"\n}"
            }
          }
        },
        {
          "name": "Google Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/google", "host": ["{{baseUrl}}"], "path": ["auth", "google"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"<google-id-token>\"\n}"
            }
          }
        },
        {
          "name": "Dev Login (non-prod only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/dev", "host": ["{{baseUrl}}"], "path": ["auth", "dev"] }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Matches",
      "item": [
        {
          "name": "List Matches",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/matches",
              "host": ["{{baseUrl}}"],
              "path": ["matches"],
              "query": [
                { "key": "stage", "value": "GROUP_STAGE", "disabled": true },
                { "key": "group", "value": "A", "disabled": true },
                { "key": "status", "value": "SCHEDULED", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Match Detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/matches/{{matchId}}", "host": ["{{baseUrl}}"], "path": ["matches", "{{matchId}}"] }
          }
        }
      ]
    },
    {
      "name": "Predictions",
      "item": [
        {
          "name": "Create / Update Prediction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/predictions", "host": ["{{baseUrl}}"], "path": ["predictions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matchId\": \"{{matchId}}\",\n  \"homeGoals\": 2,\n  \"awayGoals\": 1\n}"
            }
          }
        },
        {
          "name": "My Predictions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/predictions/mine",
              "host": ["{{baseUrl}}"],
              "path": ["predictions", "mine"],
              "query": [
                { "key": "stage", "value": "GROUP_STAGE", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Predictions for Match",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/predictions/match/{{matchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["predictions", "match", "{{matchId}}"],
              "query": [
                { "key": "leagueId", "value": "{{leagueId}}", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leagues",
      "item": [
        {
          "name": "Create League",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/leagues", "host": ["{{baseUrl}}"], "path": ["leagues"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My League\"\n}"
            }
          }
        },
        {
          "name": "Add League Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/leagues/{{leagueId}}/admins", "host": ["{{baseUrl}}"], "path": ["leagues", "{{leagueId}}", "admins"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{memberUserId}}\"\n}"
            }
          }
        },
        {
          "name": "Remove League Admin",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/leagues/{{leagueId}}/admins/{{memberUserId}}", "host": ["{{baseUrl}}"], "path": ["leagues", "{{leagueId}}", "admins", "{{memberUserId}}"] }
          }
        },
        {
          "name": "Join League",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/leagues/join", "host": ["{{baseUrl}}"], "path": ["leagues", "join"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteCode\": \"ABC123\"\n}"
            }
          }
        },
        {
          "name": "My Leagues",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/leagues", "host": ["{{baseUrl}}"], "path": ["leagues"] }
          }
        },
        {
          "name": "Get League (with Leaderboard)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/leagues/{{leagueId}}", "host": ["{{baseUrl}}"], "path": ["leagues", "{{leagueId}}"] }
          }
        },
        {
          "name": "Leave League",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/leagues/{{leagueId}}/leave", "host": ["{{baseUrl}}"], "path": ["leagues", "{{leagueId}}", "leave"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Manual Sync",
          "request": {
            "method": "POST",
            "header": [
              { "key": "x-sync-api-key", "value": "{{syncApiKey}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/sync", "host": ["{{baseUrl}}"], "path": ["admin", "sync"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"syncFixtures\": true,\n  \"processResults\": true\n}"
            }
          }
        }
      ]
    }
  ]
}
